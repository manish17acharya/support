# Copy this file to .env.docker and fill in real values before running docker compose
# Usage: docker compose --env-file .env.docker up -d

# Laravel app key — generate with: php artisan key:generate --show
APP_KEY=base64:CHANGE_ME

# MySQL root password (choose a strong password)
DB_ROOT_PASSWORD=change_me_strong_password

# Public URL of the server (used for CORS + app URL)
APP_URL=http://localhost

# Host port to expose the app on (default 80)
PORT=80

# Sanctum stateful domain (usually same as APP_URL hostname)
SANCTUM_DOMAIN=localhost
